# --- LLM gateway (required) ---
# Single gateway for all heterogeneous models. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional per-role model slug overrides (OpenRouter model IDs).
# Defaults are set in src/deep_researcher/config.py
DR_MODEL_PLANNER=
DR_MODEL_PERSPECTIVE=
DR_MODEL_CRITIC=
DR_MODEL_JUDGE=
DR_MODEL_FALLBACK=

# Ordered provider fallback chain (comma-separated OpenRouter slugs) tried after
# a role's primary model fails. Leave blank for the built-in default chain.
DR_FALLBACK_CHAIN=

# --- Observability (optional) ---
# Set a LangSmith key to enable live tracing (put the trace on the projector).
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=deep-researcher

# --- Retrieval ---
# Primary web search. Get a key at https://app.tavily.com
TAVILY_API_KEY=
# Semantic Scholar works without a key but a key raises rate limits (optional).
SEMANTIC_SCHOLAR_API_KEY=

# --- Email delivery ---
# Primary email provider. Get a key at https://resend.com/api-keys
RESEND_API_KEY=
# "from" address must be on a verified Resend domain, or use onboarding@resend.dev for testing.
RESEND_FROM=Deep Researcher <onboarding@resend.dev>

# --- Behaviour tuning (optional) ---
DR_TOP_N=8
# Per-attempt LLM timeout (s). Keep >=40: slower models fall back to a manual
# JSON round-trip, and a tight timeout trips the degraded fallback plan.
DR_API_TIMEOUT=40
# Max simultaneous in-flight LLM calls (keeps the parallel debate under rate limits).
DR_MAX_CONCURRENCY=6
DR_CACHE_DIR=data/cache
